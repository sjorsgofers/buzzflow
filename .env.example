# Kopieer dit bestand naar .env.local en vul in wat je hebt.
# Alles wat leeg blijft draait automatisch in demo-modus.

# Naam van de app (zichtbaar in de interface en in mails)
NEXT_PUBLIC_APP_NAME="Mijn Dansschool"

# Geheime sleutel voor sessies en wachtwoorden — VERPLICHT in productie.
# Genereer bijv. met: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
APP_SECRET=

# ── Google Sheets (ledenbestand als live database) ─────────────────────────
# Service-account aanmaken in Google Cloud Console → sleutel (JSON) downloaden.
# Deel je spreadsheet met het service-account e-mailadres (rechten: bewerker).
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Plak de private key uit het JSON-bestand, met \n voor regeleinden:
GOOGLE_PRIVATE_KEY=

# ── Gmail (automatische mails) ──────────────────────────────────────────────
# OAuth2-client aanmaken in Google Cloud Console → refresh token genereren
# (zie README stap 4).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_FROM="Mijn Dansschool <info@mijndansschool.nl>"

# ── Mollie (SEPA-incasso, betaallinks, storneringen) ────────────────────────
# API-key uit je Mollie-dashboard (test_... om te testen, live_... voor echt)
MOLLIE_API_KEY=

# ── Google Agenda ───────────────────────────────────────────────────────────
# Agenda-ID's vind je in Google Agenda → instellingen → "Agenda integreren".
# Deel beide agenda's met het service-account e-mailadres.
CALENDAR_ID_ROOSTER=
CALENDAR_ID_PROEFLESSEN=

# ── Cron (maandelijkse automatische Kids-upgrade) ───────────────────────────
# Zelfgekozen geheim; gebruik hetzelfde in je cron-aanroep.
CRON_SECRET=

# Publieke URL van de app (nodig voor Mollie-webhooks zodra je live gaat)
APP_URL=http://localhost:3000
